# ─────────────────────────────────────────────────────────────
# Nutrifit AI — template di configurazione
# ─────────────────────────────────────────────────────────────
# Copia questo file in `.env` e incolla le tue chiavi.
# `.env` e' gia' in .gitignore — NON committarlo.
#
# Le chiavi si generano da https://openrouter.ai/keys
# Puoi usare 3 chiavi distinte (una per modello) o la stessa chiave
# per tutti. Se una chiave specifica manca, il server usa
# OPENROUTER_API_KEY come fallback.

# ─── Chiavi per-modello ───
OPENROUTER_API_KEY_GEMMA=sk-or-v1-YOUR_GEMMA_KEY_HERE
OPENROUTER_API_KEY_LLAMA=sk-or-v1-YOUR_LLAMA_KEY_HERE
OPENROUTER_API_KEY_QWEN=sk-or-v1-YOUR_QWEN_KEY_HERE

# ─── Chiave generica (fallback) ───
OPENROUTER_API_KEY=

# ─── Modello di default — valori ammessi: gemma | llama | qwen ───
DEFAULT_MODEL=gemma

# ─── (Opzionale) Porta server — default 3000 ───
# PORT=3000

# ─── (Opzionale) Referer inviato a OpenRouter (se pubblichi online) ───
# OPENROUTER_REFERER=https://tuo-dominio.com
